# Ignore common unwanted files globally
**/.DS_Store
**/.env
**/__pycache__/
*.py[cod]
**/.conda/

#Ignore IDE files
.cursor/
.windsurf/

# ignore test files in root dir
/*.test.py

# Ignore all contents of the virtual environment directory
.venv/

# obsolete folders
memory/
knowledge/custom/
instruments/

# Handle logs directory
logs/**
!logs/**/

# Handle tmp and usr directory
tmp/**
!tmp/**/
usr/**
!usr/**/

# Handle knowledge directory

# Global rule to include .gitkeep files anywhere
!**/.gitkeep

# for browser-use
agent_history.gif

.agent/**
.claude/**

# CORTEX profile credentials — sensitive values in settings.json, never commit
agents/cortex/settings.json

# Virtual environment (venv, not .venv)
venv/

# Runtime logs and temp files
server.log
tmp_*.py
tmp_*.txt
tests_test_*_out.txt

# Root-level scratch test scripts (not the real test suite)
/test_d_integration.py
/test_phase_c.py
/test_python_diagnosis.py
/test_tier1_quick.py

# Ruflo / Claude internal tooling
.swarm/
.claude-flow/
